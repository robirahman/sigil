{
  "name": "sigilonline",
  "version": "1.0.0",
  "description": "Sigil Online",
  "main": "app.py",
  "scripts": {
    "dev": "FLASK_APP=app.py FLASK_ENV=development flask run",
    "format": "npm run lint-css && prettier --write \"./static/css/*.css\" \"./static/scripts/*.js\" \"./templates/v2/*.html\" && npm run lint-js",
    "lint-css": "stylelint \"static/css/*.css\" --fix",
    "lint-js": "eslint \"./static/scripts/**\" --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sigilite/sigilonline.git"
  },
  "author": "Andreas Voellmer",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sigilite/sigilonline/issues"
  },
  "homepage": "https://github.com/sigilite/sigilonline",
  "devDependencies": {
    "eslint": "^8.18.0",
    "eslint-plugin-import": "^2.26.0",
    "prettier": "^2.7.1",
    "prettier-plugin-organize-attributes": "^0.0.5",
    "stylelint": "^14.9.1",
    "stylelint-config-standard": "^26.0.0"
  },
  "private": true
}
